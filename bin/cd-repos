#!/bin/bash
# cd-repos: リポジトリ移動コマンド

set -euo pipefail

REPOS="${XDG_DATA_HOME:-$HOME/.local/share}/repos"

cmd_list() {
  cd "$REPOS" && ls -ltd --time-style='+%Y-%m-%dT%H:%M:%S' ./*/*/*/ 2>/dev/null | while read -r _ _ _ _ _ ts d; do
    d="${d%/}"  # remove trailing slash
    [[ -e "$d/.git" || -d "$d/.jj" ]] || continue

    local p="${d#./}"
    local color="\033[34m"  # blue for directory
    local link=""
    if [[ -L "$d" ]]; then
      color="\033[36m"  # cyan for symlink
      link=" -> $(readlink "$d")"
    fi

    # 2文字マーク: 1文字目=Git, 2文字目=jj
    # Git: G=実体, W=worktree, -=なし
    # jj:  J=実体, W=workspace, -=なし
    local git_mark jj_mark
    if [[ -d "$d/.git" ]]; then
      git_mark="\033[34mG\033[0m"  # blue: git repo
    elif [[ -f "$d/.git" ]]; then
      git_mark="\033[35mW\033[0m"  # magenta: git worktree (blue+R)
    else
      git_mark="\033[90m-\033[0m"  # gray: no git
    fi
    if [[ -d "$d/.jj/repo" ]]; then
      jj_mark="\033[32mJ\033[0m"  # green: jj repo
    elif [[ -e "$d/.jj/repo" ]]; then
      jj_mark="\033[33mW\033[0m"  # yellow: jj workspace (green+R)
    else
      jj_mark="\033[90m-\033[0m"  # gray: no jj
    fi
    echo -e "${git_mark}${jj_mark} $ts ${color}$p${link}\033[0m"
  done
}

cmd_preview() {
  local line="$1"
  # ANSI カラーコードを除去
  line=$(echo "$line" | sed 's/\x1b\[[0-9;]*m//g')
  local mark="${line%% *}"
  local rest="${line#* }"
  local p="${rest#* }"  # skip timestamp
  p="${p%% -> *}"       # シンボリックリンク矢印以降を除去
  local r="$REPOS/$p"

  # jj repo check
  if [[ -d "$r/.jj" ]]; then
    # jj workspace の場合、実体リポジトリのパスを表示
    if [[ -f "$r/.jj/repo" ]]; then
      local jj_parent=$(cat "$r/.jj/repo")
      echo "jj workspace of: ${jj_parent%/.jj/repo}"
    fi
    # 関連 bookmark の詳細 (@git, @origin 含む)
    local related_bookmarks=$(jj -R "$r" log -r '@ | trunk()' --no-graph -T 'if(bookmarks, bookmarks ++ "\n")' --no-pager 2>/dev/null | sort -u)
    if [[ -n $related_bookmarks ]]; then
      echo "--- bookmarks ---"
      echo "$related_bookmarks" | while read -r bm; do
        [[ -n $bm ]] && jj -R "$r" bookmark list --all "$bm" --color=always --no-pager 2>/dev/null
      done
    fi
    # trunk から @ までの直線1行表示
    echo "--- jj ---"
    # refs データを収集して色付け
    # local: 35(マゼンタ), remote: 4;35(UL+マゼンタ)@4;2;35(UL+薄マゼンタ), tag: 31(赤), HEAD: 2;31(薄赤)
    local refs_data=$(jj -R "$r" log -r 'trunk()::@' --no-graph --color=never --no-pager \
      -T 'change_id.shortest(4) ++ "|" ++ local_bookmarks ++ "|" ++ remote_bookmarks.join(",") ++ "|" ++ tags.join(",") ++ "|" ++ if(git_head, "HEAD", "") ++ "\n"' 2>/dev/null | \
      awk -F'|' '{
        refs=""
        # local_bookmarks: マゼンタ
        if (length($2) > 0) refs=sprintf("\033[35m%s\033[0m", $2)
        # remote_bookmarks: UL+マゼンタ @ UL+薄マゼンタ
        if (length($3) > 0) {
          n=split($3, rbs, ",")
          for (i=1; i<=n; i++) {
            if (length(refs) > 0) refs=refs ", "
            if (match(rbs[i], /@/)) {
              left=substr(rbs[i], 1, RSTART-1)
              right=substr(rbs[i], RSTART)
              refs=refs sprintf("\033[4;35m%s\033[0m\033[4;2;35m%s\033[0m", left, right)
            } else {
              refs=refs sprintf("\033[4;35m%s\033[0m", rbs[i])
            }
          }
        }
        # tags: 赤
        if (length($4) > 0) { if (length(refs) > 0) refs=refs ", "; refs=refs sprintf("\033[31m%s\033[0m", $4) }
        # HEAD: 薄赤
        if (length($5) > 0) { if (length(refs) > 0) refs=refs ", "; refs=refs sprintf("\033[1;3;31m%s\033[0m", $5) }
        print $1 "|" refs
      }')
    # jj 色付き出力と refs を結合
    paste -d$'\t' \
      <(jj -R "$r" log -r 'trunk()::@' --no-graph --color=always --no-pager \
        -T 'concat(committer.timestamp().format("%Y-%m-%dT%H:%M:%S%z"), if(current_working_copy, " @", "  "), " ", change_id.shortest(4), " ", commit_id.shortest(7), if(description, " " ++ description.first_line()), " (", author.name(), ")\n")' 2>/dev/null) \
      <(echo "$refs_data") | \
    while IFS=$'\t' read -r jj_line refs_line; do
      local refs="${refs_line#*|}"
      if [[ -n "$refs" ]]; then
        echo -e "$jj_line ($refs)"
      else
        echo "$jj_line"
      fi
    done | head -8
  fi

  # git repo check
  if [[ -e "$r/.git" ]]; then
    # git worktree の場合、実体リポジトリのパスを表示
    if [[ -f "$r/.git" ]]; then
      local git_dir=$(sed 's/^gitdir: //' "$r/.git")
      local git_parent="${git_dir%/.git/worktrees/*}"
      echo "git worktree of: $git_parent"
    fi
    local branch=$(git -C "$r" branch --show-current 2>/dev/null)
    local status=$(git -C "$r" status --short 2>/dev/null | cut -c1-2 | sort | uniq -c | awk '{print $2":"$1}' | tr '\n' ' ')
    local wt_count=$(git -C "$r" worktree list 2>/dev/null | wc -l | tr -d ' ')
    echo "Branch: $branch  ${status:-(clean)}  Worktrees: $wt_count"
    echo "--- git log ---"
    git -C "$r" tr --color=always -5 2>/dev/null
  fi
}

cmd_search() {
  local self="$0"
  local query="${1:-}"

  local selected
  selected=$(cmd_list | fzf --exact --no-mouse --select-1 --exit-0 --ansi --no-sort \
    --query "$query" \
    --preview "$self preview {}" \
    --preview-window 'up,70%,wrap' \
    --bind 'ctrl-/:toggle-preview' \
  ) || return 0

  # マーク・タイムスタンプ・シンボリックリンク矢印除去してパスのみ出力
  local rest="${selected#* }"  # skip mark
  local p="${rest#* }"          # skip timestamp
  p="${p%% -> *}"               # シンボリックリンク矢印以降を除去
  [[ -n $p ]] && echo "$REPOS/$p"
}

case ${1:-search} in
  list)    cmd_list ;;
  preview) cmd_preview "$2" ;;
  search)  cmd_search "${2:-}" ;;
  *)       echo "Usage: $0 {list|preview|search}" >&2; exit 1 ;;
esac
